{
  "name": "soullink-emotion-sdk",
  "version": "0.1.0-beta.1",
  "description": "Real-time character emotion and performance SDK with a local browser lab.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "predev": "npm run packages:build",
    "dev": "vite --host 127.0.0.1 --port 4173",
    "build": "npm run packages:build && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "profile:generate": "node ./scripts/generate-profile.mjs --force",
    "ai:test": "node ./scripts/test-ai.mjs",
    "packages:build": "node ./scripts/run-package-task.mjs build",
    "packages:typecheck": "node ./scripts/run-package-task.mjs typecheck",
    "packages:test": "node ./scripts/run-package-task.mjs test",
    "packages:pack:check": "node ./scripts/run-package-task.mjs pack:check && npm pack --workspace @soullink-emotion/sdk --dry-run",
    "audit:production": "npm audit --omit=dev --registry=https://registry.npmjs.org",
    "typecheck": "npm run packages:typecheck",
    "test": "npm run packages:test",
    "release:check": "npm run packages:build && npm run packages:typecheck && npm run packages:test && npm run packages:pack:check && npm run audit:production"
  },
  "dependencies": {
    "@soullink-emotion/api-client": "0.1.0-beta.1",
    "@soullink-emotion/classifier-embedding": "0.1.0-beta.1",
    "@soullink-emotion/engine": "0.1.0-beta.1",
    "@soullink-emotion/live2d-pixi": "0.1.0-beta.1",
    "@soullink-emotion/planner-openai": "0.1.0-beta.1",
    "@soullink-emotion/profile-generator": "0.1.0-beta.1",
    "@soullink-emotion/runtime-core": "0.1.0-beta.1",
    "pixi-live2d-display": "0.5.0-beta",
    "pixi.js": "7.4.3"
  },
  "devDependencies": {
    "vite": "7.3.6"
  }
}
