{
  "name": "@soullink-emotion/runtime-core",
  "version": "0.1.0-beta.1",
  "description": "Headless session orchestration for Soullink Emotion planners, classifiers, TTS, audio, clocks, and rendering hosts.",
  "license": "MIT",
  "keywords": [
    "emotion",
    "runtime",
    "live2d",
    "virtual-character",
    "tts"
  ],
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "pack:check": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@soullink-emotion/engine": "0.1.0-beta.1"
  },
  "devDependencies": {
    "@soullink-emotion/engine": "0.1.0-beta.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
